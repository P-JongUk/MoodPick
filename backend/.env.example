# MoodPick backend — 예시입니다. 복사해서 `.env.local` 로 저장한 뒤 값을 채우세요.
# 실제 API 키·비밀번호는 커밋하지 마세요.

# --- Podcast 큐레이션 (선택, 비밀값 아님) ---
# 코드에 있는 고정 영어·한국 피드 외에 RSS를 더 넣을 때: 쉼표로 구분한 URL 목록
# MOODPICK_PODCAST_RSS_FEEDS=https://example.com/podcast.xml

# iTunes 한국 스토어로 피드 URL 자동 수집 (Docker/시스템 프록시 환경에서 빈 결과가 나올 수 있음)
# MOODPICK_PODCAST_ITUNES_KR=1

# iTunes 검색어 (기본: 마음챙김 명상 불안 수면)
# MOODPICK_PODCAST_ITUNES_KR_QUERY=

# 한글 제목·설명 에피소드 우선 (기본 1). 0 이면 언어 무관 최고점만 선택
# MOODPICK_PODCAST_PREFER_KOREAN=1

# RSS/iTunes 호출 시 시스템 프록시 사용 (기본 0). Docker Desktop 프록시 때문에 피드가 깨지면 0 유지.
# 회사망 등에서 반드시 프록시가 필요할 때만 1
# MOODPICK_PODCAST_FEED_USE_SYSTEM_PROXY=0

# Apple Podcast 컬렉션 ID(쉼표). 기본은 혜안스님·보디야나선원 lookup 으로 한국 명상 RSS 확보
# MOODPICK_PODCAST_ITUNES_COLLECTION_IDS=953410161,1484477547
