#!/bin/sh

branch="$(git rev-parse --abbrev-ref HEAD)"

if [ "$branch" = "main" ]; then
  echo "[차단] main 브랜치 직접 커밋은 금지되어 있습니다."
  echo "develop 또는 feat/*, fix/* 브랜치에서 작업 후 머지하세요."
  exit 1
fi

if command -v powershell.exe >/dev/null 2>&1; then
  powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/update-context.ps1 -Quiet
  git add CONTEXT.md
elif command -v pwsh >/dev/null 2>&1; then
  pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/update-context.ps1 -Quiet
  git add CONTEXT.md
else
  echo "[info] PowerShell not found; skipping CONTEXT.md auto-refresh."
fi

exit 0
